// ============================================================================
// PAYWALL SCREEN - IAP Implementation
// ============================================================================
class PaywallScreen extends StatefulWidget {
  const PaywallScreen({super.key});

  @override
  State<PaywallScreen> createState() => _PaywallScreenState();
}

class _PaywallScreenState extends State<PaywallScreen> {
  final InAppPurchase _iap = InAppPurchase.instance;
  bool _available = false;
  bool _loading = true;
  List<ProductDetails> _products = [];
  String? _errorMessage;

  @override
  void initState() {
    super.initState();
    _initializeIAP();
  }

  Future<void> _initializeIAP() async {
    final available = await _iap.isAvailable();
    
    if (!available) {
      setState(() {
        _available = false;
        _loading = false;
        _errorMessage = "Store not available";
      });
      return;
    }

    const ids = <String>{AppConfig.premiumProductId};
    final response = await _iap.queryProductDetails(ids);
    
    setState(() {
      _available = true;
      _products = response.productDetails;
      _loading = false;
    });

    // Listen to purchase updates
    _iap.purchaseStream.listen((purchases) {
      _handlePurchaseUpdates(purchases);
    });
  }

  Future<void> _handlePurchaseUpdates(List<PurchaseDetails> purchases) async {
    for (var purchase in purchases) {
      if (purchase.status == PurchaseStatus.purchased ||
          purchase.status == PurchaseStatus.restored) {
        // Verify the purchase with your backend here if needed
        await StorageService.setPremium(true);
        
        if (mounted) {
          Navigator.pushReplacement(
            context,
            MaterialPageRoute(builder: (context) => const HomeScreen()),
          );
        }
      }
      
      if (purchase.pendingCompletePurchase) {
        await _iap.completePurchase(purchase);
      }
    }
  }

  Future<void> _buyProduct(ProductDetails product) async {
    final purchaseParam = PurchaseParam(productDetails: product);
    await _iap.buyNonConsumable(purchaseParam: purchaseParam);
  }

  Future<void> _restorePurchases() async {
    try {
      await _iap.restorePurchases();
      // If no purchases are restored, show message
      final hasPremium = await StorageService.hasPremium();
      if (!hasPremium && mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          const SnackBar(content: Text('No previous purchases found')),
        );
      }
    } catch (e) {
      if (mounted) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Restore failed: $e')),
        );
      }
    }
  }

  @override
  Widget build(BuildContext context) {
